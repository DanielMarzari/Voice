# Copy to .env.local and fill in.
# These values are read by backend/main.py via python-dotenv.

# Base URL of your Reader server, no trailing slash.
READER_BASE_URL=https://reader.danmarzari.com

# Bearer token generated from Reader → Voice Lab → "Generate Studio Token".
# Shown once on creation; paste it here.
READER_AUTH_TOKEN=

# Where F5-TTS downloads its model weights. Default is fine.
HF_HOME=./backend/data/cache

# Device: "mps" on Apple Silicon, "cuda" on NVIDIA, "cpu" as fallback.
TTS_DEVICE=mps

# Default engine when the user first opens the app. Can be "xtts" or "f5".
# The user can always switch per voice in the UI.
TTS_ENGINE_DEFAULT=xtts

# Coqui's TTS package requires explicit opt-in to download XTTS weights.
# The backend sets this automatically, but if you run the Python modules
# directly (e.g. for scripting) set it here too.
COQUI_TOS_AGREED=1
