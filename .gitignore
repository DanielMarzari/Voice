# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
.Python
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Node
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
next-env.d.ts

# Local data (voice profiles are per-user, stay local).
# Use ** so nested paths (e.g. backend/backend/data/cache when uvicorn is
# launched from the backend/ dir with a relative HF_HOME) are also ignored.
**/data/profiles/
**/data/cache/
# Model artifacts: heavy binaries stay local, small metadata JSONs commit.
# Listing extensions individually (instead of `**/data/models/`) so that
# files like vocos_meta.json inside the dir can be tracked — git's
# gitignore semantics don't let a `!` exception re-include a file whose
# parent directory was already matched by a broader rule.
**/data/models/*.onnx
**/data/models/*.onnx_data
**/data/models/*.safetensors
**/data/models/*.pt
**/data/models/*.ckpt
**/data/models/*.bin
# User-uploaded reference clips — never commit; they're personal voice
# samples the user dropped in via the Design tab's Upload button.
**/data/presets/user/
# Deep Clone training datasets — segmented WAVs + transcripts + checkpoints.
# Can be hundreds of MB per voice; always user-specific.
**/data/training/
# Reader credentials live here — written by reader_client.set_config().
# Never commit; bearer tokens must stay local.
**/data/config.json
# Also catch the misnested dir pattern outright.
backend/backend/

# Env
.env
.env.local
.env.*.local
!.env.example

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp

# Spike artifacts — large ONNX weights and audio samples don't belong in git.
# The *.md reports in spikes/ and spikes/results/*.json DO commit.
spikes/**/*.onnx
spikes/**/*.onnx_data
spikes/**/*.wav
spikes/**/*.mp3
spikes/**/*.safetensors
spikes/**/*.pt
spikes/**/*.ckpt
spikes/**/artifacts/

# Exception: Spike D zero-shot outputs are small (~1.6 MB total across 11
# WAVs) and are the primary artifact of the spike — the subjective quality
# verdict is only reproducible if you can listen to them. Keep them.
!spikes/spike_d_zero_shot/outputs/*.wav
